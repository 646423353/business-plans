# 应用配置
PORT=3000
NODE_ENV=development

# 数据库配置 (MySQL)
DATABASE_URL=mysql://root:password@localhost:3306/business_planner

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# 配额配置
QUOTA_FREE_DAILY_LIMIT=1
QUOTA_PRO_DAILY_LIMIT=10
