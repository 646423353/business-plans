generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Case {
  id             String   @id @default(uuid()) @db.Char(36)
  title          String   @db.VarChar(100)
  industry       String   @db.VarChar(50)
  summary        String   @db.Text
  highlights     String?  @db.Text
  businessDesign String   @map("business_design") @db.Text
  functionDesign String   @map("function_design") @db.Text
  evaluation     String   @db.Text
  risk           String   @db.Text
  isPublished    Boolean  @default(true) @map("is_published")
  viewCount      Int      @default(0) @map("view_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([industry])
  @@index([isPublished])
  @@map("cases")
}

model Document {
  id          String   @id @default(uuid()) @db.Char(36)
  projectId   String   @map("project_id") @db.Char(36)
  version     Int      @default(1)
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(200)
  content     String   @db.Text
  customLabel String?  @map("custom_label") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, version])
  @@index([type])
  @@map("documents")
}

model Industry {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(50)
  code      String   @unique @db.VarChar(20)
  icon      String?  @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@map("industries")
}

model Message {
  id        String   @id @default(uuid()) @db.Char(36)
  projectId String   @map("project_id") @db.Char(36)
  turn      Int
  role      String   @db.VarChar(20)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([projectId])
  @@index([projectId, turn])
  @@map("messages")
}

model Project {
  id                  String     @id @default(uuid()) @db.Char(36)
  userId              String     @map("user_id") @db.Char(36)
  name                String     @db.VarChar(100)
  industry            String     @db.VarChar(50)
  status              String     @default("analyzing") @db.VarChar(20)
  currentTurn         Int        @default(0) @map("current_turn")
  directionConfirmed  Boolean    @default(false) @map("direction_confirmed")
  directionConfirmTurn Int?      @map("direction_confirm_turn")
  riskFlag            Boolean    @default(false) @map("risk_flag")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")
  documents           Document[]
  messages            Message[]
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([deletedAt])
  @@index([status])
  @@index([updatedAt])
  @@index([userId])
  @@map("projects")
}

model User {
  id                  String    @id @default(uuid()) @db.Char(36)
  username            String    @db.VarChar(50)
  email               String    @unique @db.VarChar(100)
  phone               String?   @db.VarChar(20)
  avatar              String?   @db.Text
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  role                String    @default("free") @db.VarChar(20)
  createdAt           DateTime  @default(now()) @map("created_at")
  lastLoginAt         DateTime? @map("last_login_at")
  quotaDailyUsed      Int       @default(0) @map("quota_daily_used")
  quotaDailyResetDate DateTime? @map("quota_daily_reset_date")
  projects            Project[]

  @@index([createdAt])
  @@index([phone])
  @@index([role])
  @@map("users")
}
